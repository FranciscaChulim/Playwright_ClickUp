{
  "name": "playwright_clickup",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "pw": "npx playwright test",
    "pw:smoke": "npx playwright test --grep @smoke",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report",
    "test:report": "npm run pw; npm run allure:generate && npm run allure:open",
    "pw:headed": "npx playwright test --headed",
    "pw:login": "npm run pw -- login.spec.ts --headed; npm run allure:generate && npm run allure:open",
    "pw:workspace": "npm run pw -- workspace.spec.ts; npm run allure:generate && npm run allure:open",
    "pw:tasks": "npm run pw -- tasks.spec.ts; npm run allure:generate && npm run allure:open"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FranciscaChulim/Playwright_ClickUp.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/FranciscaChulim/Playwright_ClickUp/issues"
  },
  "homepage": "https://github.com/FranciscaChulim/Playwright_ClickUp#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.7.2",
    "eslint": "^10.3.0",
    "eslint-plugin-playwright": "^2.10.2",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
